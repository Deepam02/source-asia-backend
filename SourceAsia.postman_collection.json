{
  "info": {
    "name": "Source Asia Backend - Full Suite",
    "description": "Comprehensive test suite for the Source Asia backend assignment.\n\nHOW TO RUN: open any numbered folder and click Run (Collection Runner), or run the whole collection top to bottom. Folders 1-6 are independent and self-seeding (they generate unique SKUs and user IDs per run, so you can re-run safely). Every request has assertions, so a green run proves the behaviour the assignment grades.\n\nbaseUrl defaults to http://localhost:3000. Start the server first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "rlUser",
      "value": "",
      "type": "string"
    },
    {
      "key": "dupSku",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Smoke Test (happy path)",
      "item": [
        {
          "name": "POST /request - accepted",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('status accepted', () => pm.expect(pm.response.json().status).to.eql('accepted'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "request"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"smoke-user\",\n  \"payload\": {\n    \"action\": \"click\"\n  }\n}"
            }
          }
        },
        {
          "name": "GET /stats - returns counts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('has accepted count', () => pm.expect(b).to.have.property('accepted'));",
                  "pm.test('has rejected count', () => pm.expect(b).to.have.property('rejected'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stats?user_id=smoke-user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stats"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "smoke-user"
                }
              ]
            }
          }
        },
        {
          "name": "POST /products - creates product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('returns an id', () => pm.expect(pm.response.json().id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Smoke Widget\",\n  \"sku\": \"SMOKE-{{$timestamp}}\",\n  \"image_urls\": [\n    \"https://cdn.example.com/smoke/img-1.jpg\"\n  ],\n  \"video_urls\": [\n    \"https://cdn.example.com/smoke/demo.mp4\"\n  ]\n}"
            }
          }
        },
        {
          "name": "GET /products - lists products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('products is an array', () => pm.expect(pm.response.json().products).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?offset=0&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        }
      ],
      "description": "Run this first. One happy-path call per endpoint to confirm the server is up and responding."
    },
