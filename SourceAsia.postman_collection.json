    {
      "name": "4. Catalog - core flow (Part 2)",
      "item": [
        {
          "name": "POST /products - create (saves id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('has id', () => pm.expect(b.id).to.be.a('string'));",
                  "pm.test('image_urls present in detail', () => pm.expect(b.image_urls).to.have.lengthOf(2));",
                  "pm.test('video_urls present in detail', () => pm.expect(b.video_urls).to.have.lengthOf(1));",
                  "pm.collectionVariables.set('productId', b.id);",
                  "console.log('Saved productId =', b.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Flow Widget\",\n  \"sku\": \"FLOW-{{$timestamp}}\",\n  \"image_urls\": [\n    \"https://cdn.example.com/flow/img-1.jpg\",\n    \"https://cdn.example.com/flow/img-2.jpg\"\n  ],\n  \"video_urls\": [\n    \"https://cdn.example.com/flow/demo.mp4\"\n  ]\n}"
            }
          }
        },
        {
          "name": "GET /products - list has NO media arrays",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const list = pm.response.json().products;",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('list is non-empty', () => pm.expect(list.length).to.be.above(0));",
                  "pm.test('list items omit image_urls (list-vs-detail design)', () => {",
                  "  list.forEach(p => pm.expect(p).to.not.have.property('image_urls'));",
                  "});",
                  "pm.test('list items omit video_urls', () => {",
                  "  list.forEach(p => pm.expect(p).to.not.have.property('video_urls'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?offset=0&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "GET /products/{id} - detail HAS media arrays",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('detail includes image_urls', () => pm.expect(b.image_urls).to.be.an('array'));",
                  "pm.test('detail includes video_urls', () => pm.expect(b.video_urls).to.be.an('array'));",
                  "pm.test('id matches created product', () => pm.expect(b.id).to.eql(pm.collectionVariables.get('productId')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{productId}}"
                }
              ]
            }
          }
        },
        {
          "name": "POST /products/{id}/media - append + dedup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('dedup: img-1 not duplicated, img-3 added (total 3)', () => pm.expect(b.image_urls).to.have.lengthOf(3));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/:id/media",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                ":id",
                "media"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{productId}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image_urls\": [\n    \"https://cdn.example.com/flow/img-1.jpg\",\n    \"https://cdn.example.com/flow/img-3.jpg\"\n  ],\n  \"video_urls\": []\n}"
            }
          }
        }
      ],
      "description": "The core Part 2 sequence, fully chained. The created product id is saved automatically, so run TOP TO BOTTOM (or run the folder). Proves the list-vs-detail design: list responses omit media arrays, detail responses include them."
    },
